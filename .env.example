# Superwall API Keys
# Get these from your Superwall dashboard: https://superwall.com/dashboard
# Each platform has its own public API key
SUPERWALL_IOS_KEY=your_ios_public_api_key_here
SUPERWALL_ANDROID_KEY=your_android_public_api_key_here
# Fallback key if platform-specific keys are not set
SUPERWALL_API_KEY=your_public_api_key_here

# Vercel OAuth Configuration
# Get these from your Vercel OAuth application: https://vercel.com/account/settings/oauth
VERCEL_CLIENT_ID=your_vercel_client_id_here
VERCEL_CLIENT_SECRET=your_vercel_client_secret_here
VERCEL_REDIRECT_URI=your_bridge_url_here/callback
