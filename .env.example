# Vercel OAuth Configuration
# Copy this file to .env and fill in your actual credentials

# Vercel OAuth Client ID
VERCEL_CLIENT_ID=your_client_id_here

# Vercel OAuth Client Secret
VERCEL_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI (must match your Vercel app callback URL)
VERCEL_REDIRECT_URI=https://your-callback-url.vercel.app/callback
