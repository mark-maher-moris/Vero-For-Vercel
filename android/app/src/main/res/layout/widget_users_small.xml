<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="12dp">

    <!-- Main content -->
    <LinearLayout
        android:id="@+id/widget_data_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="visible">

        <TextView
            android:id="@+id/widget_project_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Project"
            android:textColor="#888888"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24h"
            android:textColor="#666666"
            android:textSize="8sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/widget_total_users"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="online"
            android:textColor="#666666"
            android:textSize="8sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/widget_online_users"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#50E3C2"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_bounce_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—%"
            android:textColor="#888888"
            android:textSize="9sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/widget_last_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#444444"
            android:textSize="7sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- No project selected -->
    <TextView
        android:id="@+id/widget_no_project"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Tap to\nconfigure"
        android:textColor="#666666"
        android:textSize="10sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Lock overlay -->
    <LinearLayout
        android:id="@+id/widget_lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pro"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</FrameLayout>
