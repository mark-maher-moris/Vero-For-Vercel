<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANALYTICS · "
                android:textColor="#4A9EFF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_project_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Project"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A1A2E"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24h VISITORS"
                    android:textColor="#666666"
                    android:textSize="7sp" />

                <TextView
                    android:id="@+id/widget_visitors_24h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A1A2E"
                android:padding="8dp"
                android:layout_marginLeft="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BOUNCE RATE"
                    android:textColor="#666666"
                    android:textSize="7sp" />

                <TextView
                    android:id="@+id/widget_bounce_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—%"
                    android:textColor="#F5A623"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Analytics content -->
        <LinearLayout
            android:id="@+id/widget_analytics_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRAFFIC SOURCES"
                android:textColor="#555555"
                android:textSize="8sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout android:id="@+id/source_row_1" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/source_name_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="" android:textColor="#B0B0B0" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/source_count_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4A9EFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/source_row_2" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/source_name_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="" android:textColor="#B0B0B0" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/source_count_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4A9EFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/source_row_3" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/source_name_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="" android:textColor="#B0B0B0" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/source_count_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4A9EFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/source_row_4" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/source_name_4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="" android:textColor="#B0B0B0" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/source_count_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4A9EFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:id="@+id/source_row_5" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/source_name_5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="" android:textColor="#B0B0B0" android:textSize="10sp" android:maxLines="1" android:ellipsize="end" />
                <TextView android:id="@+id/source_count_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4A9EFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Analytics disabled -->
        <TextView
            android:id="@+id/widget_analytics_disabled"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Enable Vercel Analytics\nto use this widget"
            android:textColor="#555555"
            android:textSize="10sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- No project -->
        <TextView
            android:id="@+id/widget_no_project"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Tap to configure widget"
            android:textColor="#444444"
            android:textSize="10sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Footer -->
        <TextView
            android:id="@+id/widget_last_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#333333"
            android:textSize="7sp"
            android:gravity="end"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Lock overlay -->
    <LinearLayout
        android:id="@+id/widget_lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="28sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upgrade to Pro" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Open app to unlock" android:textColor="#888888" android:textSize="10sp" android:layout_marginTop="4dp" />

    </LinearLayout>

</FrameLayout>
